<div class="tag-container">
    <div class="tag-list">
        <div class="tag-row"></div>
    </div>
</div>

<style>
.tag-container {
    width: 100%;
    overflow: hidden;
    padding: 2rem 0;
    background: transparent;
    margin: 20px 0;
}

.tag-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.tag-row {
    display: flex;
    white-space: nowrap;
    animation: scrollTags 30s linear infinite;
}

.tag {
    display: inline-block;
    padding: 8px 16px;
    margin: 4px;
    border-radius: 20px;
    color: white;
    background: rgba(255,255,255,0.1);
    transition: transform 0.3s ease;
    font-family: Arial, sans-serif;
    font-size: 14px;
    background: linear-gradient(45deg, #4a90e2, #357abd);
    box-shadow: 0 2px 5px rgba(0,0,0,0.2);
}

.tag:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.3);
}

@keyframes scrollTags {
    0% { transform: translateX(100%); }
    100% { transform: translateX(-100%); }
}
</style>

<script>
const TAGS = [
    'Dr. Khaled Ghalwash', 'Dr. Mohammed Ghalwash', 'Alexandria, Egypt',
    'Plastic Surgery', 'Aesthetic Excellence', 'Patient Care',
    'Professional Experience', 'Surgical Expertise', 'Medical Innovation',
    'Beauty Enhancement', 'Surgical Precision', 'Patient Safety'
];

function initializeTagCloud() {
    const row = document.querySelector('.tag-row');
    if (!row) return;

    TAGS.forEach(tag => {
        const tagElement = document.createElement('div');
        tagElement.className = 'tag';
        tagElement.textContent = tag;
        row.appendChild(tagElement);
    });

    // Clone tags for smooth infinite scroll
    const tags = Array.from(row.children);
    tags.forEach(tag => {
        row.appendChild(tag.cloneNode(true));
    });
}

document.addEventListener('DOMContentLoaded', initializeTagCloud);
</script>