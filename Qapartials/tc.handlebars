<div class="tag-container">
    <div class="tag-list">
        <div class="tag-row"></div>
    </div>
</div>

<style>
.tag-container {
    width: 100%;
    overflow: hidden;
    height: 100px;
    position: relative;
    margin: 20px auto;
}

.tag-list {
    position: relative;
    z-index: 1;
    padding: 0.5rem 0;
}

.tag-row {
    white-space: nowrap;
    animation: scrollTags 30s linear infinite;
}

.tag {
    display: inline-block;
    padding: 8px 16px;
    margin: 4px;
    border-radius: 20px;
    background: #f3f4f6;
    color: #333;
    font-size: 14px;
    transition: all 0.3s ease;
}

.tag:hover {
    transform: translateY(-2px);
    background: #e5e7eb;
}

@keyframes scrollTags {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
</style>

<script>
(function() {
    const tags = [
        'Dr. Khaled Ghalwash', 'Dr. Mohammed Ghalwash', 'Alexandria, Egypt',
        'Plastic Surgery', 'Aesthetic Excellence', 'Patient Care',
        'Professional Experience', 'Surgical Expertise', 'Medical Innovation'
    ];

    function createAndAppendTags() {
        const row = document.querySelector('.tag-row');
        if (!row) return;

        const tagsHtml = tags.map(tag => `<span class="tag">${tag}</span>`).join('');
        row.innerHTML = tagsHtml + tagsHtml; // Double for continuous scroll
    }

    // Execute immediately when script loads
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', createAndAppendTags);
    } else {
        createAndAppendTags();
    }
})();
</script>