<style>
.tag-container {
    overflow: hidden;
    position: relative;
    height: 120px;
    width: 80%;
    margin: 2rem auto;
    mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent);
}

.tag-row {
    display: flex;
    white-space: nowrap;
    animation: scroll 30s linear infinite;
    will-change: transform;
}

.tag {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    margin: 0.5rem;
    border-radius: 25px;
    font-size: 0.875rem;
    background: #f0f0f0;
    color: #333;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    overflow: hidden;
}

.tag::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(255,255,255,0.8) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.tag.center {
    transform: translateY(-8px) scale(1.15);
    background: #ffffff;
    box-shadow: 
        0 10px 20px rgba(0,0,0,0.1),
        0 6px 6px rgba(0,0,0,0.1),
        0 0 15px rgba(255,255,255,0.5),
        0 0 25px rgba(255,255,255,0.3);
    z-index: 10;
}

.tag.center::before {
    opacity: 1;
}

@keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
}
</style>

<div class="tag-container">
    <div class="tag-list">
        <div class="tag-row"></div>
    </div>
</div>

<script>
(function() {
    const tags = [
        'Dr. Khaled Ghalwash', 'Dr. Mohammed Ghalwash', 'Alexandria, Egypt',
        'Plastic Surgery', 'Aesthetic Excellence', 'Patient Care',
        'Professional Experience', 'Surgical Expertise', 'Medical Innovation'
    ];

    function createTags() {
        const tagRow = document.querySelector('.tag-row');
        if (!tagRow) return;

        // Create tags three times for smooth infinite scroll
        for (let i = 0; i < 3; i++) {
            tags.forEach(text => {
                const tag = document.createElement('div');
                tag.className = 'tag';
                tag.textContent = text;
                tagRow.appendChild(tag);
            });
        }
    }

    function checkCenter() {
        const container = document.querySelector('.tag-container');
        if (!container) return;

        const containerCenter = container.offsetLeft + container.offsetWidth / 2;
        const tolerance = 50; // Adjust this value to change the "center" zone size

        document.querySelectorAll('.tag').forEach(tag => {
            const rect = tag.getBoundingClientRect();
            const tagCenter = rect.left + rect.width / 2;
            const distanceFromCenter = Math.abs(tagCenter - containerCenter);

            if (distanceFromCenter < tolerance) {
                tag.classList.add('center');
            } else {
                tag.classList.remove('center');
            }
        });
    }

    createTags();
    setInterval(checkCenter, 50);

    // Pause animation on hover
    const tagRow = document.querySelector('.tag-row');
    if (tagRow) {
        tagRow.addEventListener('mouseenter', () => {
            tagRow.style.animationPlayState = 'paused';
        });

        tagRow.addEventListener('mouseleave', () => {
            tagRow.style.animationPlayState = 'running';
        });
    }
})();
</script>