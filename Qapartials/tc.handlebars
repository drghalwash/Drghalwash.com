
<style>
.tag-container {
    overflow: hidden;
    position: relative;
    height: auto;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    transform: translateZ(0);
    will-change: transform;
}

.tag-list {
    position: relative;
    z-index: 1;
    padding: 0.5rem 0;
    transform: translateZ(0);
}

.tag-row {
    display: flex;
    white-space: nowrap;
    animation: scroll 20s linear infinite;
    will-change: transform;
    transition: transform 0.3s ease-out;
}

.tag {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    margin: 0.375rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 500;
    background-color: #f3f4f6;
    color: #111827;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    user-select: none;
    will-change: transform, box-shadow;
}

.tag:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(66, 135, 245, 0.3);
}

.tag.active {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 0 20px rgba(66, 135, 245, 0.8);
    animation: pulseGlow 1.5s infinite;
}

@keyframes pulseGlow {
    0% { box-shadow: 0 0 15px rgba(66, 135, 245, 0.6); }
    50% { box-shadow: 0 0 25px rgba(66, 135, 245, 0.9); }
    100% { box-shadow: 0 0 15px rgba(66, 135, 245, 0.6); }
}

@keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
}
</style>

<div class="tag-container">
    <div class="tag-list">
        <div class="tag-row"></div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const tags = [
        'Dr. Khaled Ghalwash', 'Dr. Mohammed Ghalwash', 'Alexandria, Egypt',
        'Plastic Surgery', 'Aesthetic Excellence', 'Patient Care',
        'Professional Experience', 'Surgical Expertise', 'Medical Innovation'
    ];

    function createTags() {
        const tagRow = document.querySelector('.tag-row');
        if (!tagRow) return;

        const tagsHTML = tags.map(tag => `<div class="tag">${tag}</div>`).join('');
        tagRow.innerHTML = tagsHTML + tagsHTML + tagsHTML;

        const allTags = tagRow.querySelectorAll('.tag');
        let activeTimeout;

        allTags.forEach(tag => {
            tag.addEventListener('click', (e) => {
                e.preventDefault();
                clearTimeout(activeTimeout);
                
                const wasActive = tag.classList.contains('active');
                allTags.forEach(t => t.classList.remove('active'));
                
                if (!wasActive) {
                    tag.classList.add('active');
                    tagRow.style.animationPlayState = 'paused';
                    
                    activeTimeout = setTimeout(() => {
                        tag.classList.remove('active');
                        tagRow.style.animationPlayState = 'running';
                    }, 2000);
                } else {
                    tagRow.style.animationPlayState = 'running';
                }
            });

            tag.addEventListener('mouseenter', () => {
                tagRow.style.animationPlayState = 'paused';
            });

            tag.addEventListener('mouseleave', () => {
                if (!document.querySelector('.tag.active')) {
                    tagRow.style.animationPlayState = 'running';
                }
            });
        });
    }

    createTags();
});
</script>
