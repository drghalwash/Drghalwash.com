
<style>
.tag-container {
    overflow: hidden;
    position: relative;
    height: 100px;
    width: 50%;
    max-width: 800px;
    margin: 0 auto;
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-font-smoothing: antialiased;
}

.tag-list {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
}

.tag-row {
    display: flex;
    white-space: nowrap;
    animation: scroll 30s linear infinite;
    will-change: transform;
    transform: translateZ(0);
}

.tag {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    margin: 0.375rem;
    border-radius: 20px;
    font-size: 0.875rem;
    background-color: #e8e6e3;
    color: #4a4a4a;
    cursor: pointer;
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                background-color 0.3s ease;
    user-select: none;
    will-change: transform, box-shadow;
    box-shadow: 0 0 8px rgba(180, 175, 170, 0.2);
}

.tag:hover {
    background-color: #f0eeeb;
    box-shadow: 0 0 12px rgba(180, 175, 170, 0.3);
}

.tag.active {
    transform: translateY(-5px) scale(1.05);
    background-color: #f5f3f0;
    box-shadow: 0 0 20px rgba(180, 175, 170, 0.4);
}

.tag.glowing {
    animation: glow 1s ease-in-out;
}

@keyframes glow {
    0% { box-shadow: 0 0 8px rgba(180, 175, 170, 0.2); }
    50% { box-shadow: 0 0 25px rgba(180, 175, 170, 0.6); }
    100% { box-shadow: 0 0 8px rgba(180, 175, 170, 0.2); }
}

@keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
}
</style>

<div class="tag-container">
    <div class="tag-list">
        <div class="tag-row"></div>
    </div>
</div>

<script>
(function() {
    const questions = {{{json zones}}}.flatMap(zone => 
        zone.categories.flatMap(category => 
            category.questions.map(q => q.question_text)
        )
    );

    function createRandomGlow() {
        const tag = document.createElement('div');
        tag.className = 'tag';
        const randomQuestion = questions[Math.floor(Math.random() * questions.length)];
        tag.textContent = randomQuestion || 'Loading...';
        
        // Random glow timing
        const startDelay = Math.random() * 5000;
        const duration = 1000 + Math.random() * 2000;
        
        setTimeout(() => {
            const glowInterval = setInterval(() => {
                if (!document.body.contains(tag)) {
                    clearInterval(glowInterval);
                    return;
                }
                tag.classList.add('glowing');
                setTimeout(() => tag.classList.remove('glowing'), duration);
            }, 5000 + Math.random() * 5000);
        }, startDelay);
        
        return tag;
    }

    function createTags() {
        const tagRow = document.querySelector('.tag-row');
        if (!tagRow) return;

        const fragment = document.createDocumentFragment();
        
        // Create tags three times for smooth infinite scroll
        for (let i = 0; i < 3; i++) {
            for (let j = 0; j < 5; j++) {
                fragment.appendChild(createRandomGlow());
            }
        }
        
        tagRow.appendChild(fragment);

        let isAnimationPaused = false;
        let activeTag = null;

        tagRow.addEventListener('click', (e) => {
            const tag = e.target.closest('.tag');
            if (!tag) return;

            if (activeTag === tag) {
                tag.classList.remove('active');
                activeTag = null;
                tagRow.style.animationPlayState = 'running';
                isAnimationPaused = false;
                return;
            }

            if (activeTag) {
                activeTag.classList.remove('active');
            }

            tag.classList.add('active');
            activeTag = tag;
            tagRow.style.animationPlayState = 'paused';
            isAnimationPaused = true;

            setTimeout(() => {
                if (isAnimationPaused) {
                    tag.classList.remove('active');
                    tagRow.style.animationPlayState = 'running';
                    isAnimationPaused = false;
                    activeTag = null;
                }
            }, 2000);
        });

        tagRow.addEventListener('mouseenter', () => {
            if (!isAnimationPaused) {
                tagRow.style.animationPlayState = 'paused';
            }
        });

        tagRow.addEventListener('mouseleave', () => {
            if (!isAnimationPaused) {
                tagRow.style.animationPlayState = 'running';
            }
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', createTags);
    } else {
        createTags();
    }
})();
</script>
