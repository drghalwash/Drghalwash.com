<script>
function openModal(imageId) {
  console.log('Opening modal for image ID:', imageId);
  const modal = document.getElementById('exampleModalCenter');
  const hiddenInput = document.getElementById('hiddenImageId');
  if (hiddenInput) {
    hiddenInput.value = imageId;
  }
  const bootstrapModal = new bootstrap.Modal(modal);
  bootstrapModal.show();
}
</script>

<script>
  const toggleButton = document.getElementById('toggle-button');
  const menu = document.getElementById('menu');

  // Toggle the menu visibility on button click
  toggleButton.addEventListener('click', (event) => {
    event.stopPropagation(); // Prevent click from propagating to the document
    menu.classList.toggle('active');
  });

  // Close the menu when clicking outside of it
  document.addEventListener('click', (event) => {
    if (!menu.contains(event.target) && !toggleButton.contains(event.target)) {
      menu.classList.remove('active'); // Remove the active class if clicking outside
    }
  });

  // Function to reset menu visibility for larger screens
  const resetMenu = () => {
    if (window.innerWidth > 768) {
      menu.classList.remove('active'); // Remove the active class in desktop view
    }
  };

  // Listen for window resize events
  window.addEventListener('resize', resetMenu);

  // Initial check to reset menu on page load
  resetMenu();
</script>
		<script src="/js/header.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const nav = document.querySelector(".site-nav ");
        const menuToggle = document.querySelector(".sticky-wrapper");
        menuToggle.addEventListener("click", function () {
          nav.classList.toggle("active"); // Toggle the class on the nav
        });
      });
</script>

<script>
  // Select the navbar, logo, links, and toggle spans
  const navbar = document.querySelector(".unique-navbar");
  const logo = document.querySelector(".distinct-logo img");
  const links = document.querySelectorAll(".uncommon-link");
  const toggleSpans = document.querySelectorAll(".menu-toggle .toggle-lines span");

  // Paths for the original and scrolled state logos
  const originalLogoSrc = "/images/white-logo.png"; 
  const scrolledLogoSrc = "/images/black-logo.png"; 

  // Function to handle scroll behavior
  function handleScroll() {
    if (window.scrollY > 0) {
      // Add scrolled class when the user scrolls down
      navbar.classList.add("scrolled");

      // Update logo for scrolled state
      logo.src = scrolledLogoSrc;

      // Update link colors
      links.forEach((link) => {
        link.style.color = "#4c4b4b"; 
      });

      // Update toggle span colors
      toggleSpans.forEach((span) => {
        span.style.backgroundColor = "#4c4b4b"; 
      });
    } else {
      // Remove scrolled class when at the top of the page
      navbar.classList.remove("scrolled");

      // Ensure the logo is white when at the top
      logo.src = originalLogoSrc;

      // Reset link colors to inherit the default color
      links.forEach((link) => {
        link.style.color = "white";
      });

      // Reset toggle span colors
      toggleSpans.forEach((span) => {
        span.style.backgroundColor = "white"; 
      });
    }
  }

  // Ensure the logo is white when the page loads
  window.addEventListener("DOMContentLoaded", () => {
    if (window.scrollY === 0) {
      logo.src = originalLogoSrc;
    }
  });

  // Attach the scroll event listener
  window.addEventListener("scroll", handleScroll);
</script>
