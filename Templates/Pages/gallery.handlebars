  <style>
    /* Custom header styles */
    .heading-pages {
      width: 100%;
      height: 25vh;
      background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('/images/Photo Gallery/header.jpg');
      background-size: cover;
      background-position: center;
      padding: 40px 0;
      color: white;
      text-align: center;
      margin-bottom: 50px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .heading-pages h1 {
      font-size: 40px;
      font-weight: 600;
      color: white;
      margin-bottom: 10px;
    }

    .heading-pages p {
      font-size: 16px;
      color: white;
    }

    .heading-pages a {
      color: #fff;
      text-decoration: none;
    }

    /* Gallery container styles */
    .gallery-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* Category heading styles */
    .category-title {
      font-size: 28px;
      color: #333;
      border-bottom: 2px solid #eaeaea;
      padding-bottom: 10px;
      margin-bottom: 30px;
      text-align: center;
    }

    /* Gallery row styles */
    .gallery-row {
      display: flex;
      flex-wrap: wrap;
      margin-bottom: 40px;
      justify-content: center;
    }

    /* Gallery item styles */
    .gallery-item {
      margin: 15px;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      cursor: pointer;
      position: relative;
    }

    .gallery-item:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* Different item sizes for visual interest */
    .row-one .gallery-item {
      width: 80%;
      height: 400px;
    }

    .row-two .gallery-item {
      width: calc(50% - 30px);
      height: 300px;
    }

    .row-three .gallery-item {
      width: calc(33.333% - 30px);
      height: 250px;
    }

    .row-four .gallery-item {
      width: calc(25% - 30px);
      height: 200px;
    }

    .row-five .gallery-item {
      width: calc(20% - 30px);
      height: 180px;
    }

    /* Item caption styles */
    .item-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(0, 0, 0, 0.7);
      color: white;
      padding: 10px;
      text-align: center;
      transform: translateY(100%);
      transition: transform 0.3s ease;
    }

    .gallery-item:hover .item-caption {
      transform: translateY(0);
    }

    .item-caption h3 {
      margin: 0;
      font-size: 16px;
    }

    /* Lock icon for private galleries */
    .private-icon {
      position: absolute;
      top: 10px;
      right: 10px;
      background: rgba(0, 0, 0, 0.6);
      color: white;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 14px;
    }

    /* Responsive adjustments */
    @media (max-width: 992px) {
      .row-four .gallery-item,
      .row-five .gallery-item {
        width: calc(33.333% - 30px);
      }
    }

    @media (max-width: 768px) {
      .row-three .gallery-item,
      .row-four .gallery-item,
      .row-five .gallery-item {
        width: calc(50% - 30px);
      }
    }

    @media (max-width: 576px) {
      .row-two .gallery-item,
      .row-three .gallery-item,
      .row-four .gallery-item,
      .row-five .gallery-item {
        width: calc(100% - 30px);
      }
      
      .heading-pages h1 {
        font-size: 30px;
      }
      
      .category-title {
        font-size: 24px;
      }
    }

    /* Password modal styles */
    .password-modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.7);
      overflow: auto;
    }

    .modal-content {
      background-color: #fefefe;
      margin: 15% auto;
      padding: 20px;
      border: 1px solid #888;
      width: 80%;
      max-width: 400px;
      border-radius: 10px;
    }

    .close-button {
      color: #aaa;
      float: right;
      font-size: 28px;
      font-weight: bold;
      cursor: pointer;
    }

    .close-button:hover {
      color: black;
    }

    .password-form {
      margin-top: 20px;
    }

    .password-form input {
      width: 100%;
      padding: 10px;
      margin: 10px 0;
      border: 1px solid #ddd;
      border-radius: 5px;
    }

    .password-form button {
      width: 100%;
      padding: 10px;
      background-color: #4CAF50;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
    }

    .password-form button:hover {
      background-color: #45a049;
    }

    .password-error {
      color: red;
      margin-top: 10px;
      font-size: 14px;
    }
  </style>

