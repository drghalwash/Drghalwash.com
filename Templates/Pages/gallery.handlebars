{{!-- Meta section --}}
<div class="heading-pages">
  <h1>{{gallery.name}}</h1>
  <p><a href="/Home">Home </a> > Photo Gallery > {{gallery.name}}</p>
</div>

{{!-- Gallery intro section --}}
<div class="section">
  <div class="container">
    <div class="row justify-content-between align-items-center">
      <div class="col-lg-5 mb-4 mb-lg-0 order-lg-2" data-aos="fade-up">
        <img src="/images/gallery/{{gallery.image}}" alt="{{gallery.name}}" class="img-fluid">
      </div>
      <div class="col-lg-5" data-aos="fade-up" data-aos-delay="100">
        <h6 class="heading mb-4">{{gallery.title}}</h6>
        {{{gallery.description}}}
      </div>
    </div>
  </div>
</div>

{{!-- Gallery grid section --}}
<div class="photo-gallery">
  <h1>We invite you to click on each link below to view Before & After Photos with {{gallery.name}} Procedures Description</h1>
  <div class="custom-container">
    {{#if rowsHtml}}
      {{{rowsHtml}}}
    {{else}}
      <p>No images are available for this gallery.</p>
    {{/if}}
  </div>
</div>

{{!-- Private images modal --}}
<div class="modal2 fade" id="exampleModalCenter" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content rounded-0">
      <div class="modal-body p-4 px-5">
        <div class="main-content text-center">
          <a href="#" class="close-btn" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true"><span class="icon-close2"></span></span>
          </a>
          <form action="/galleries/private_images" method="post">
            <label>This link is password protected</label>
            <input type="hidden" name="id" id="hiddenImageId">
            <input type="password" name="password" placeholder="Enter password" class="form-control text-center" required>
            <button type="submit" class="btn btn-primary">Enter</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

{{!-- Moving background section --}}
<div class="moving-background2">
  <div class="overlay"></div>
  <div class="content-of-moving-background">
    <h1>Hear from Our Patients</h1>
    <p>Dr. Khaled – You changed my life. I stand in the mirror and smile. I have pride when I walk down the street. This is best thing in my life right now .</p>
    <div class="button-of-moving-background">
      <a href="/Contact">Contact Us</a>
    </div>
  </div>
</div>

