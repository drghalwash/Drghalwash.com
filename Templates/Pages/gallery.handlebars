        </div>
      </div>

      <div class="col-lg-2 ml-auto">
        <div class="widget">
          <h3 class="footer-headers">New Patient Info</h3>
          <ul class="list-unstyled float-left links">
            <li><a href="/Guidelines">Photography Guidelines</a></li>
            <li><a href="/Policies">Policies & Guidelines</a></li>
            <li><a href="/Finance">Financing</a></li>
            <li><a href="/Diet">Diet and Nutrition</a></li>
            <li><a href="/Drain_Care">Drain Care</a></li>
