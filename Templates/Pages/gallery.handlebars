      <div class="col-lg-2 ml-auto">
        <div class="widget">
          <h3 class="footer-headers">About</h3>
          <ul class="list-unstyled float-left links">
            <li><a href="/About_Us/Dr_Khaled">Meet Dr.Khaled</a></li>
            <li><a href="/About_Us/Dr_Mohamed">Meet Dr.Mohammed</a></li>
            <li><a href="/Choose">How to Choose A Plastic Surgeon</a></li>
